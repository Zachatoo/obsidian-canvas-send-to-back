		"lint": "eslint ."
	},
	"keywords": [
		"obsidian-plugin",
		"typescript"
	],
	"author": "Zachatoo",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.35.0",
		"@types/node": "^16.11.6",
		"@typescript-eslint/utils": "^8.42.0",
		"esbuild": "0.25.0",
		"eslint": "^9.35.0",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^16.3.0",
		"obsidian": "1.12.3",
		"tslib": "2.4.0",
		"typescript": "^4.9.0",
		"typescript-eslint": "^8.42.0"
	}
}
