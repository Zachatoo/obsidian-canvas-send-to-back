{
	"name": "obsidian-canvas-send-to-back",
	"version": "0.1.0",
	"description": "Send a card in Obsidian Canvas to be behind all other cards.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
